# Шаблон секретов для Streamlit Cloud.
# Локально секреты можно держать в .env (см. .env.example) — этот файл нужен
# в основном для хостинга. На share.streamlit.io вставьте эти значения в
# раздел "Secrets" приложения (а не коммитьте файл).
#
# Скопируйте в .streamlit/secrets.toml и заполните (файл уже в .gitignore).

MAL_CLIENT_ID = "ваш_client_id"
MAL_CLIENT_SECRET = "ваш_client_secret"

# Публичный адрес приложения. Должен дословно совпадать с одним из
# App Redirect URL в настройках приложения на myanimelist.net.
MAL_REDIRECT_URI = "https://ваш-домен.streamlit.app/"
